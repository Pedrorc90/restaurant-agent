{
  "info": {
    "name": "Restaurant Agent API",
    "_postman_id": "restaurant-agent-collection",
    "description": "Collection para probar los endpoints del Restaurant Agent (Priorities 1, 2, 3 y 4)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "sessionToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminKey",
      "value": "your-admin-key-here",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "la-cazuela",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Verifica que el servidor está corriendo."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "POST /chat — nueva sesión (sin sessionId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.sessionId) pm.collectionVariables.set('sessionId', json.sessionId);",
                  "if (json.sessionToken) pm.collectionVariables.set('sessionToken', json.sessionToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Hola, ¿qué platos tenéis disponibles?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Primera llamada sin sessionId. El servidor genera sessionId + sessionToken y los guarda en variables de colección automáticamente."
          },
          "response": []
        },
        {
          "name": "POST /chat — continuar conversación",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"¿Tenéis opciones vegetarianas?\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"{{sessionToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Segunda vuelta con el mismo sessionId+sessionToken. Requiere haber ejecutado 'nueva sesión' primero."
          },
          "response": []
        },
        {
          "name": "POST /chat — trigger get_menu",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"¿Qué tienen de menú?\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"{{sessionToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Claude debe llamar la tool get_menu y responder con los datos de BD."
          },
          "response": []
        },
        {
          "name": "POST /chat — trigger get_opening_hours",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"¿A qué hora cierran?\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"{{sessionToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Claude debe llamar la tool get_opening_hours y responder con horarios y reglas del negocio."
          },
          "response": []
        },
        {
          "name": "POST /chat — trigger get_order_status",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"¿Dónde está mi pedido?\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"{{sessionToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Claude llama get_order_status usando el sessionId de la sesión actual (ya no acepta session_id externo). Crea un pedido primero con POST /orders."
          },
          "response": []
        },
        {
          "name": "POST /chat — trigger place_order (confirmar pedido)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Quiero 1 pollo asado y 1 agua. Sí, confirmo el pedido.\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"{{sessionToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Claude debe llamar place_order cuando el cliente confirma. Verifica en GET /orders/:sessionId que el pedido fue guardado."
          },
          "response": []
        },
        {
          "name": "POST /chat — streaming SSE",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Cuéntame el menú del día con detalle.\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"{{sessionToken}}\",\n  \"stream\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Activa el modo streaming SSE. La respuesta llega como eventos 'data: {...delta}' y termina con 'data: [DONE]'. El sessionToken también se devuelve en headers X-Session-ID y X-Session-Token."
          },
          "response": []
        },
        {
          "name": "POST /chat — 401 token inválido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Intento acceder a sesión ajena\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"token-falso-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Debe devolver 401 UNAUTHORIZED porque el sessionToken no corresponde al sessionId."
          },
          "response": []
        },
        {
          "name": "POST /chat — validación fallida (sin message)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"{{sessionToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            },
            "description": "Debe devolver 400 porque falta el campo 'message'."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Session",
      "item": [
        {
          "name": "GET /session — listar sesiones (admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" },
              { "key": "X-Admin-Key", "value": "{{adminKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/session",
              "host": ["{{baseUrl}}"],
              "path": ["session"]
            },
            "description": "Devuelve la lista de sessionIds activos. Requiere X-Admin-Key."
          },
          "response": []
        },
        {
          "name": "GET /session — 401 sin admin key",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/session",
              "host": ["{{baseUrl}}"],
              "path": ["session"]
            },
            "description": "Debe devolver 401 porque falta X-Admin-Key."
          },
          "response": []
        },
        {
          "name": "DELETE /session/:id — borrar sesión propia",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" },
              { "key": "X-Session-Token", "value": "{{sessionToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/session/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["session", "{{sessionId}}"]
            },
            "description": "Elimina el historial de la sesión. Requiere X-Session-Token válido. Devuelve 204 No Content."
          },
          "response": []
        },
        {
          "name": "DELETE /session/:id — 401 sin token",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/session/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["session", "{{sessionId}}"]
            },
            "description": "Debe devolver 401 porque falta X-Session-Token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "POST /orders — crear pedido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"{{sessionToken}}\",\n  \"items\": [\n    { \"name\": \"Pollo asado (medio)\", \"qty\": 1, \"price\": 12.00 },\n    { \"name\": \"Agua\", \"qty\": 1, \"price\": 1.00 }\n  ],\n  \"total\": 13.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            },
            "description": "Crea un pedido manualmente. Requiere sessionToken válido."
          },
          "response": []
        },
        {
          "name": "GET /orders/:sessionId — consultar pedido",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" },
              { "key": "X-Session-Token", "value": "{{sessionToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{sessionId}}"]
            },
            "description": "Devuelve el último pedido de la sesión. Requiere X-Session-Token válido."
          },
          "response": []
        },
        {
          "name": "GET /orders/:sessionId — 401 sin token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{sessionId}}"]
            },
            "description": "Debe devolver 401 porque falta X-Session-Token."
          },
          "response": []
        },
        {
          "name": "GET /orders/:sessionId — 404 sesión sin pedido",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" },
              { "key": "X-Session-Token", "value": "{{sessionToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Debe devolver 401 (token no corresponde al sessionId) o 404 si el token fuese válido para esa sesión vacía."
          },
          "response": []
        },
        {
          "name": "POST /orders — validación fallida (sin items)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"sessionToken\": \"{{sessionToken}}\",\n  \"total\": 13.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["orders"]
            },
            "description": "Debe devolver 400 porque falta el campo 'items'."
          },
          "response": []
        }
      ]
    }
  ]
}
